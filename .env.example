# Copy to ".env" in the project root. Loaded automatically by the API/CLI.

# --- Playwright (default) ---
# Optional US residential proxy (example: Bright Data)
ZILLOW_PROXY_SERVER=http://brd.superproxy.io:33335
ZILLOW_PROXY_USERNAME=brd-customer-YOUR_ACCOUNT_ID-zone-YOUR_ZONE-country-us-session-zillow_1
ZILLOW_PROXY_PASSWORD=YOUR_PROXY_ZONE_PASSWORD

ZILLOW_HEADLESS=1
ZILLOW_RETRY_HEADED_ON_BLOCK=1
# Faster Playwright (optional): ZILLOW_SKIP_ZILLOW_HOME=1
# ZILLOW_WARMUP_MS=800 ZILLOW_POST_SEARCH_MS=1500 ZILLOW_POST_DETAIL_MS=1200
# ZILLOW_TIMEOUT_MS=20000 ZILLOW_MAX_RETRIES=2 ZILLOW_RETRY_BACKOFF_SEC=0.5
# ZILLOW_COOKIES_FILE=C:\path\to\export.json
# Default cookie path when file exists: cookies/zillow.json (gitignored)

# CORS_ALLOW_ORIGINS=https://your-app.pages.dev,http://localhost:5173

# --- Apify (ZILLOW_BACKEND=apify; pip install -e ".[apify]") ---
# ZILLOW_BACKEND=apify
# APIFY_TOKEN=your_token
# Default actor ENK9p4RZHg0iVso52 — override with APIFY_ACTOR_ID
# APIFY_PROPERTY_STATUS=RECENTLY_SOLD
# APIFY_EXTRACT_BUILDING_UNITS=all
# APIFY_START_URLS_JSON=[{"url":"https://www.zillow.com/homedetails/..."}]
# APIFY_SEARCH_RESULTS_DATASET_ID=...
# APIFY_WAIT_SECS=600
# APIFY_ACTOR_TIMEOUT_SECS=300
# HGPH: APIFY_ACTOR_ID=HGPHGu8INtQpCeF3x APIFY_SCRAPE_TYPE=zpids
# maxcopell: APIFY_ACTOR_ID=maxcopell/zillow-scraper — use map URL or APIFY_INPUT_JSON / APIFY_ZILLOW_SEARCH_URL
# APIFY_INPUT_JSON={"searchUrls":[...],"extractionMethod":"PAGINATION_WITH_ZOOM_IN"}
